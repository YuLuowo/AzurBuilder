generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AzurLaneData {
  key       String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Equipment {
  key         String @id
  name        String
  type        Int
  rarity      Int
  nationality Int
  icon        String
}

model Item {
  key    String @id
  name   String
  icon   String
  rarity Int
  type   Int
  id     Int
}

model Ship {
  key         String   @id
  name        String
  painting    String
  nationality Int
  rarity      Int
  type        Int
  tag_list    String[]
  group_type  Int
  trans       Boolean
  ship_equip  Json
}

model ShipSkill {
  key          String @id
  group_type   Int
  skills       Json
  trans_skills Json
  shipName     String
}

model ShipTransform {
  key        String @id
  transforms Json
  shipName   String
}
